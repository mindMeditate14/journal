# Server
NODE_ENV=development
PORT=5005
HOST=0.0.0.0

# Database
MONGO_URI=mongodb://localhost:27017/nexusjournal_db
MONGODB_URI=mongodb://localhost:27017/nexusjournal_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRE=7d

# AYUSH Entry Integration
AYUSH_ENTRY_API_URL=http://localhost:5001/api
AYUSH_ENTRY_API_KEY=your-api-key

# Google Gemini API
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# AI Provider (gemini|minimax)
AI_PROVIDER=gemini

# Minimax API (required when AI_PROVIDER=minimax)
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M1

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=/tmp/nexusjournal/uploads

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@nexusjournal.com

# AWS S3 (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=nexusjournal-pdfs

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/nexusjournal/app.log

# CORS
CORS_ORIGIN=http://localhost:5173,https://nexusjournal.mind-meditate.com

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100
